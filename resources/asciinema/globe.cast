[21.215039, "o", "\u001b[m\u001b[K\u001b[01;32m\u001b[K`9|\u001b[m\u001b[K\r\n\u001b[01;32m\u001b[K|\u001b[m\u001b[K\u001b[01;44m\u001b[K       \u001b[m\u001b[K\u001b[01;32m\u001b[K`HMMMMMMMMMMMMMMMMMMMMb##|\u001b[m\u001b[K\u001b[01;44m\u001b[K      \u001b[m\u001b[K\u001b[01;32m\u001b[K`F.\u001b[m\u001b[K\u001b[01;44m\u001b[K \u001b[m\u001b[K\u001b[01;32m\u001b[K:?\u001b[m\u001b[K\r\n\u001b[01;32m\u001b[KH\u001b[m\u001b[K\u001b[01;44m\u001b[K        \u001b[m\u001b[K\u001b[01;32m\u001b[K`\"*\"'\"`#MMMMMMMMMMMMMMM?\u001b[m\u001b[K\u001b[01;44m\u001b[K         \u001b[m\u001b[K\u001b[01;32m\u001b[K'\u001b[m\u001b[K\u001b[01;44m\u001b[K  \u001b[m\u001b[K\u001b[01;32m\u001b[Kk\u001b[m\u001b[K\r\n\u001b[01;32m\u001b[KM.\u001b[m\u001b[K\u001b[01;44m\u001b[K               \u001b[m\u001b[K\u001b[01;32m\u001b[KMMMMMMMMMMMMM\"'\u001b[m\u001b[K\u001b[01;44m\u001b[K             \u001b[m\u001b[K\u001b[01;32m\u001b[KH\u001b[m\u001b[K\r\n\u001b[01;32m\u001b[KMMH.\u001b[m\u001b[K\u001b[01;44m\u001b[K             \u001b[m\u001b[K\u001b[01;32m\u001b[K`HMMMMMMMMMM:\u001b[m\u001b[K\u001b[01;44m\u001b[K               \u001b[m\u001b[K\u001b[01;32m\u001b[K|\u001b[m\u001b[K\r\n\u001b[01;32m\u001b[K&MM|\u001b[m\u001b[K\u001b[01;44m\u001b[K              \u001b[m\u001b[K\u001b[01;32m\u001b[K`MMMMMMMMMM,\u001b[m\u001b[K\u001b[01;44m\u001b[K               \u001b[m\u001b[K\u001b[01;32m\u001b[K-\u001b[m\u001b[K\r\n\u001b[01;32m\u001b[K`MM|\u001b[m\u001b[K\u001b[01;44m\u001b[K              \u001b[m\u001b[K\u001b[01;32m\u001b[KdMMMMMMMMMM|.oH\u001b[m\u001b[K\u001b[01;44m\u001b[K            \u001b[m\u001b[K\u001b[01;32m\u001b[K:\u001b[m\u001b[K\r\n \u001b[01;32m\u001b[K9ML\u001b[m\u001b[K\u001b[01;44m\u001b[K              \u001b[m\u001b[K\u001b[01;32m\u001b[K`HMMMMMMM?\u001b[m\u001b[K\u001b[01;44m\u001b[K  \u001b[m\u001b[K\u001b[01;32m\u001b[KdH'\u001b[m\u001b[K\u001b[01;44m\u001b[K "]
