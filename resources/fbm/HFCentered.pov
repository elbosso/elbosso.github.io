camera{location <0, 1, -3> look_at <0,-1,1> translate <0,-0.2,0>}
light_source {<40, 40, -5> rgb 1} 

height_field {
  png "hdhf.png" smooth
  translate -0.5
  scale <5,0.3,5>
  texture{
	//pigment{colour rgb <0,1,0>} finish{ambient 0.4}}
	pigment {
		image_map {
			png "tex.png"
			interpolate 4
		}
		translate -0.5
		scale <5,5,0>
		rotate<90,0,0>
	}
  }
}
